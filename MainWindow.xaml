<Window
    x:Class="CredentialProviderAPP.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CredentialProviderAPP"
    Width="1280"
    Height="720"
    Background="#1E1E1E"
    Deactivated="Window_Deactivated"
    Icon="Resources/Icon.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen">

    <Grid>

        <StackPanel
            Width="360"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Image
                Width="90"
                Height="90"
                Margin="0,0,0,10"
                HorizontalAlignment="Center"
                Source="Resources/Icon.bmp" />

            <TextBlock
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                FontSize="24"
                Foreground="White"
                Text="CredentialProviderAPP" />

            <TextBlock
                x:Name="lblMensagem"
                Margin="0,0,0,15"
                Foreground="White"
                Text="Digite o usuário"
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <StackPanel
                Margin="0,0,0,15"
                HorizontalAlignment="Center"
                Orientation="Horizontal">

                <TextBox
                    x:Name="txtUser"
                    Width="200"
                    Height="32"
                    Margin="0,0,10,0"
                    FontSize="14" />

                <Button
                    x:Name="btnBuscar"
                    Width="80"
                    Height="32"
                    Click="BuscarUsuario_Click"
                    Content="Buscar" />

            </StackPanel>

            <Image
                x:Name="imgQR"
                Width="200"
                Height="200"
                Margin="0,0,0,15"
                Visibility="Collapsed" />

            <TextBox
                x:Name="txtCode"
                Height="35"
                Margin="0,0,0,10"
                HorizontalContentAlignment="Center"
                FontSize="20"
                MaxLength="6"
                Visibility="Collapsed" />

            <Button
                x:Name="btnGerarQR"
                Height="40"
                Margin="0,0,0,10"
                Click="GerarQR_Click"
                Content="Gerar QR Code"
                Visibility="Collapsed" />

            <Button
                x:Name="btnValidar"
                Height="40"
                Click="ValidarCodigo_Click"
                Content="Validar Código"
                Visibility="Collapsed" />

        </StackPanel>

    </Grid>
</Window>