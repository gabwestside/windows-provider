<Window x:Class="CredentialProviderAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CredentialProviderAPP"
        Width="1280"
        Height="720"
        Icon="Resources/Icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Topmost="True"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated">

<Grid>

<StackPanel HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="360">

<Image Source="Resources/Icon.bmp"
       Width="90"
       Height="90"
       Margin="0,0,0,10"
       HorizontalAlignment="Center"/>

<TextBlock Text="CredentialProviderAPP"
           FontSize="24"
           Foreground="White"
           HorizontalAlignment="Center"
           Margin="0,0,0,20"/>

<TextBlock x:Name="lblMensagem"
           Text="Digite o usuário"
           Foreground="White"
           TextAlignment="Center"
           Margin="0,0,0,15"
           TextWrapping="Wrap"/>

<StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,0,0,15">

<TextBox x:Name="txtUser"
         Width="200"
         Height="32"
         FontSize="14"
         Margin="0,0,10,0"/>

<Button x:Name="btnBuscar"
        Content="Buscar"
        Width="80"
        Height="32"
        Click="BuscarUsuario_Click"/>

</StackPanel>

<Image x:Name="imgQR"
       Width="200"
       Height="200"
       Visibility="Collapsed"
       Margin="0,0,0,15"/>

<TextBox x:Name="txtCode"
         Height="35"
         FontSize="20"
         MaxLength="6"
         HorizontalContentAlignment="Center"
         Visibility="Collapsed"
         Margin="0,0,0,10"/>

<Button x:Name="btnGerarQR"
        Content="Gerar QR Code"
        Height="40"
        Visibility="Collapsed"
        Margin="0,0,0,10"
        Click="GerarQR_Click"/>

<Button x:Name="btnValidar"
        Content="Validar Código"
        Height="40"
        Visibility="Collapsed"
        Click="ValidarCodigo_Click"/>

</StackPanel>

</Grid>
</Window>