<Window x:Class="CredentialProviderAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CredentialProviderAPP"
        Width="1280"
        Height="720"
        Icon="Resources/Icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400">

            <!-- Logo -->
            <Image Source="Resources/Icon.bmp"
                   Width="150"
                   Height="150"
                   Margin="0,0,0,30"
                   HorizontalAlignment="Center"/>

            <!-- Título -->
            <TextBlock Text="CredentialProviderAPP"
                       FontSize="36"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <!-- Botão suporte -->
            <Button Content="Ferramenta de Suporte"
                    Height="70"
                    Margin="0,0,0,20"
                    FontSize="20"
                    Background="#D9D9D9"
                    Click="Suporte_Click"/>

            <!-- Botão QR -->
            <Button Content="Login via QR Code"
                    Height="70"
                    FontSize="20"
                    Background="#D9D9D9"
                    Click="QRLogin_Click"/>

        </StackPanel>

    </Grid>
</Window>