<Window x:Class="CredentialProviderAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CredentialProviderAPP"
        Width="1280"
        Height="720"
        Icon="Resources/Icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid>

        <!-- Botão verificar MFA -->
        <Button x:Name="btnVerificarCodigo"
                Content="Verificar Código"
                Width="140"
                Height="30"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Click="VerificarCodigo_Click"/>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320">

            <!-- Logo -->
            <Image Source="Resources/Icon.bmp"
                   Width="90"
                   Height="90"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

            <!-- Título -->
            <TextBlock Text="CredentialProviderAPP"
                       FontSize="24"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <!-- Username + Buscar -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10">

                <TextBox x:Name="txtUser"
                         Width="200"
                         Height="32"
                         FontSize="14"
                         Margin="0,0,10,0"/>

<Button x:Name="btnBuscar"
        Content="Buscar"
        Width="80"
        Height="32"
        Click="BuscarUsuario_Click"/>
            </StackPanel>

            <!-- Botão gerar QR -->
            <Button x:Name="btnGerarQR"
                    Content="Gerar QR Code MFA"
                    Height="40"
                    Margin="0,0,0,10"
                    FontSize="14"
                    Background="#D9D9D9"
                    Click="GerarQR_Click"/>

            <!-- Secret -->
            <TextBox x:Name="txtSecret"
                     Height="30"
                     FontSize="12"
                     Margin="0,0,0,10"
                     IsReadOnly="True"/>

            <!-- QR Code -->
            <Image x:Name="imgQR"
                   Width="170"
                   Height="170"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

            <!-- Texto validação -->
            <TextBlock x:Name="lblValidacao"
                       Text="Valide o QRCode com o código do celular"
                       Foreground="White"
                       FontSize="13"
                       Margin="0,5,0,5"
                       TextAlignment="Center"/>

            <!-- Código -->
            <TextBox x:Name="txtCode"
                     Height="32"
                     FontSize="16"
                     MaxLength="6"
                     Margin="0,0,0,8"
                     HorizontalContentAlignment="Center"/>

            <!-- Botão validar -->
            <Button x:Name="btnValidar"
                    Content="Validar código"
                    Height="36"
                    FontSize="14"
                    Click="ValidarCodigo_Click"/>

        </StackPanel>

    </Grid>
</Window>