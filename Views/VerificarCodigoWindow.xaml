<Window
    x:Class="CredentialProviderAPP.Views.VerificarCodigoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verificar Código MFA"
    Width="340"
    Height="230"
    Background="#1E1E1E"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">

    <Grid>
        <StackPanel
            Width="240"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                x:Name="lblTitulo"
                Margin="0,0,0,8"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="White"
                Text="Digite o código de verificação"
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="lblSubtitulo"
                Margin="0,0,0,14"
                FontSize="12"
                Foreground="#CFCFCF"
                Text="Informe o código para continuar."
                TextAlignment="Center"
                TextWrapping="Wrap" />

            <TextBox
                x:Name="txtCode"
                Height="38"
                Margin="0,0,0,12"
                HorizontalContentAlignment="Center"
                DataObject.Pasting="TxtCode_Pasting"
                FontSize="20"
                MaxLength="6"
                PreviewTextInput="TxtCode_PreviewTextInput"
                TextChanged="TxtCode_TextChanged" />

            <Button
                x:Name="btnVerificar"
                Height="36"
                Click="Verificar_Click"
                Content="Verificar"
                IsDefault="True"
                IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>