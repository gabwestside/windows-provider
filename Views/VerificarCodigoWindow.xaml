<Window
    x:Class="CredentialProviderAPP.Views.VerificarCodigoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verificar Código MFA"
    Width="300"
    Height="200"
    Background="#1E1E1E"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="SingleBorderWindow">

    <Grid>

        <StackPanel
            Width="200"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                Margin="0,0,0,10"
                FontSize="14"
                Foreground="White"
                Text="Digite o código do celular"
                TextAlignment="Center" />

            <TextBox
                x:Name="txtCode"
                Height="35"
                Margin="0,0,0,10"
                HorizontalContentAlignment="Center"
                FontSize="20"
                MaxLength="6" />
 
            <Button
                x:Name="btnVerificar"
                Height="35"
                Click="Verificar_Click"
                Content="Verificar" />

        </StackPanel>

    </Grid>
</Window>