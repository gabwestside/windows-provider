<Window
    x:Class="CredentialProviderAPP.Views.VerificarCodigoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verificar Código MFA"
    Width="1280"
    Height="720"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>

        <!--  INPUT CÓDIGO OTP  -->
        <Style x:Key="OtpInput" TargetType="TextBox">
            <Setter Property="Background" Value="#F0F4FF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="56" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <!--  Ícone celular  -->
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="#64748B"
                                    Text="📱" />
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                                <!--  Placeholder  -->
                                <TextBlock
                                    x:Name="Ph"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Foreground="#CBD5E1"
                                    IsHitTestVisible="False"
                                    Text="000 000"
                                    Visibility="Visible" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Ph" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO VERIFICAR  -->
        <Style x:Key="BtnVerificar" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="14"
                                    Opacity="0.30"
                                    ShadowDepth="3"
                                    Color="#2563EB" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO CANCELAR (ghost)  -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#1A1D23" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--  ROOT — fundo azul claro suave  -->
    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#EEF2FF" />
                <GradientStop Offset="0.6" Color="#F0F5FF" />
                <GradientStop Offset="1" Color="#E8F0FE" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Nav top  -->
                <RowDefinition Height="*" />
                <!--  Conteúdo  -->
                <RowDefinition Height="Auto" />
                <!--  Footer  -->
            </Grid.RowDefinitions>

            <!--  ══ NAVBAR SUPERIOR ══  -->
            <Grid
                Grid.Row="0"
                Height="52"
                Margin="32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="#2563EB"
                    Text="CredentialProviderAPP" />

                <!--  Botão ?  -->
                <Border
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Center"
                    Background="#E2E8F0"
                    CornerRadius="16"
                    Cursor="Hand">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#64748B"
                        Text="?" />
                </Border>
            </Grid>

            <!--  ══ CONTEÚDO CENTRAL ══  -->
            <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Disabled">
                <StackPanel
                    Width="420"
                    Margin="0,16,0,16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <!--  ── CARD PRINCIPAL ──  -->
                    <Border ClipToBounds="True" CornerRadius="16">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="28"
                                Opacity="0.10"
                                ShadowDepth="6" />
                        </Border.Effect>

                        <StackPanel>

                            <!--  Header azul com ícone  -->
                            <Border Height="130" CornerRadius="16,16,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Offset="0" Color="#2563EB" />
                                        <GradientStop Offset="1" Color="#3B82F6" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <!--  Ícone cadeado centralizado  -->
                                <Border
                                    Width="64"
                                    Height="64"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFF22"
                                    CornerRadius="32">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="28"
                                        Text="🔒" />
                                </Border>
                            </Border>

                            <!--  Corpo branco do card  -->
                            <Border Background="White" CornerRadius="0,0,0,0">
                                <StackPanel Margin="36,24,36,0">

                                    <!--  Título e subtítulo  -->
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center"
                                        FontFamily="Segoe UI"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Foreground="#0F172A"
                                        Text="Verificar Código MFA" />
                                    <TextBlock
                                        Margin="0,0,0,24"
                                        HorizontalAlignment="Center"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Foreground="#64748B"
                                        Text="Digite o código recebido no seu celular para continuar"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />

                                    <!--  Label CÓDIGO  -->
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontFamily="Segoe UI"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#94A3B8"
                                        Text="CÓDIGO DE VERIFICAÇÃO" />

                                    <!--  Campo OTP  -->
                                    <TextBox
                                        x:Name="txtCode"
                                        Margin="0,0,0,10"
                                        KeyDown="TxtCode_KeyDown"
                                        MaxLength="6"
                                        Style="{StaticResource OtpInput}" />

                                    <!--  Linha: "Não recebi o código" + timer  -->
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Cursor="Hand"
                                            FontFamily="Segoe UI"
                                            FontSize="12"
                                            Foreground="#2563EB">
                                            <Hyperlink Foreground="#2563EB" TextDecorations="None">
                                                Não recebi o código
                                            </Hyperlink>
                                        </TextBlock>

                                        <!--  Timer regressivo  -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe UI"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="#94A3B8"
                                                Text="EXPIRA EM " />
                                            <TextBlock
                                                x:Name="lblTimer"
                                                VerticalAlignment="Center"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="#64748B"
                                                Text="00:30" />
                                        </StackPanel>
                                    </Grid>

                                    <!--  Botão VERIFICAR  -->
                                    <Button
                                        Margin="0,0,0,12"
                                        Click="Verificar_Click"
                                        Style="{StaticResource BtnVerificar}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe UI"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="VERIFICAR" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="White"
                                                Text="→" />
                                        </StackPanel>
                                    </Button>

                                    <!--  Botão CANCELAR  -->
                                    <Button
                                        Margin="0,0,0,28"
                                        Click="Cancelar_Click"
                                        Content="Cancelar"
                                        Style="{StaticResource BtnGhost}" />

                                </StackPanel>
                            </Border>

                            <!--  Badge "CONEXÃO SEGURA"  -->
                            <Border
                                Padding="0,14"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,1,0,0"
                                CornerRadius="0,0,16,16">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="🛡" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Segoe UI"
                                        FontSize="10"
                                        FontWeight="SemiBold"
                                        Foreground="#64748B"
                                        Text="CONEXÃO SEGURA E CRIPTOGRAFADA" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  ══ FOOTER ══  -->
            <Border Grid.Row="2" Padding="32,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Copyright  -->
                    <StackPanel
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,6,0"
                            FontSize="12"
                            Foreground="#94A3B8"
                            Text="🛡" />
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#94A3B8"
                            Text="2026 CredentialProviderAPP. Todos os direitos reservados." />
                    </StackPanel>

                    <!--  Links  -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#94A3B8">
                            <Hyperlink Foreground="#94A3B8" TextDecorations="None">Termos</Hyperlink>
                        </TextBlock>
                        <TextBlock
                            FontSize="11"
                            Foreground="#CBD5E1"
                            Text="  ·  " />
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#94A3B8">
                            <Hyperlink Foreground="#94A3B8" TextDecorations="None">Privacidade</Hyperlink>
                        </TextBlock>
                        <TextBlock
                            FontSize="11"
                            Foreground="#CBD5E1"
                            Text="  ·  " />
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="11"
                            Foreground="#94A3B8">
                            <Hyperlink Foreground="#94A3B8" TextDecorations="None">Suporte</Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
