<Window
    x:Class="CredentialProviderAPP.Views.ConfirmarSenhaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Trocar Senha no Próximo Login"
    Width="520"
    Height="680"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>

        <SolidColorBrush x:Key="BgPage" Color="#F5F7FA" />
        <SolidColorBrush x:Key="BorderColor" Color="#E8ECF0" />
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1D23" />
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB" />

        <!--  INPUT STYLE  -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1A1D23" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  PASSWORD BOX STYLE  -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1A1D23" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BUTTON PRIMARY  -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="12"
                                    Opacity="0.25"
                                    ShadowDepth="2"
                                    Color="#2563EB" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#B8C4E0" />
                                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BUTTON GHOST  -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="#1A1D23" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBF0F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BUTTON ICON (regenerar, mostrar/ocultar)  -->
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--  SOMBRA + CARD RAIZ  -->
    <Border
        Background="White"
        BorderBrush="#E8ECF0"
        BorderThickness="1"
        CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="32"
                Opacity="0.14"
                ShadowDepth="8"
                Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Header  -->
                <RowDefinition Height="*" />
                <!--  Corpo  -->
                <RowDefinition Height="Auto" />
                <!--  Rodapé botões  -->
            </Grid.RowDefinitions>

            <!--  ═══ HEADER ═══  -->
            <Border
                Grid.Row="0"
                BorderBrush="#E8ECF0"
                BorderThickness="0,0,0,1"
                CornerRadius="14,14,0,0"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#1A1D23"
                            Text="Trocar senha no próximo login" />
                        <TextBlock
                            x:Name="lblSubtitle"
                            Margin="0,2,0,0"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#9CA3AF"
                            Text="Definindo para 1 usuário selecionado" />
                    </StackPanel>

                    <Button
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnFechar_Click"
                        Content="✕"
                        Cursor="Hand"
                        FontSize="13"
                        Foreground="#9CA3AF" />
                </Grid>
            </Border>

            <!--  ═══ CORPO ═══  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,8">

                    <!--  INFO BANNER  -->
                    <Border
                        Margin="0,0,0,20"
                        Padding="14,10"
                        Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="15"
                                Foreground="#2563EB"
                                Text="ℹ" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#1D4ED8"
                                Text="Uma senha temporária será gerada e enviada por e-mail ao usuário. Ele deverá alterá-la no próximo acesso."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  EMAIL DO DESTINATÁRIO  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="E-mail do destinatário" />
                    <TextBox
                        x:Name="txtEmail"
                        Margin="0,0,0,18"
                        Style="{StaticResource ModernInput}">
                        <TextBox.Text>
                            usuario@empresa.com.br
                        </TextBox.Text>
                    </TextBox>

                    <!--  SENHA GERADA  -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#6B7280"
                            Text="Senha temporária" />
                        <Button
                            x:Name="btnRegerar"
                            Grid.Column="1"
                            Click="BtnRegerar_Click"
                            Style="{StaticResource BtnIcon}"
                            ToolTip="Gerar nova senha aleatória">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#2563EB"
                                    Text="↺" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#2563EB"
                                    Text="Regerar" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!--  Campo senha com botão mostrar/ocultar  -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <!--  PasswordBox (padrão oculto)  -->
                        <PasswordBox
                            x:Name="pwdSenha"
                            Grid.Column="0"
                            PasswordChanged="PwdSenha_Changed"
                            Style="{StaticResource ModernPasswordBox}" />

                        <!--  TextBox visível quando "mostrar"  -->
                        <TextBox
                            x:Name="txtSenhaVisivel"
                            Grid.Column="0"
                            Style="{StaticResource ModernInput}"
                            TextChanged="TxtSenhaVisivel_Changed"
                            Visibility="Collapsed" />

                        <Button
                            x:Name="btnMostrarSenha"
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Click="BtnMostrarSenha_Click"
                            Style="{StaticResource BtnIcon}"
                            ToolTip="Mostrar / Ocultar senha">
                            <TextBlock
                                x:Name="lblOlho"
                                FontSize="14"
                                Foreground="#9CA3AF"
                                Text="👁" />
                        </Button>
                    </Grid>

                    <!--  INDICADOR DE FORÇA  -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            x:Name="barForca1"
                            Grid.Column="0"
                            Height="4"
                            Margin="0,0,3,0"
                            Background="#E8ECF0"
                            CornerRadius="2" />
                        <Border
                            x:Name="barForca2"
                            Grid.Column="1"
                            Height="4"
                            Margin="0,0,3,0"
                            Background="#E8ECF0"
                            CornerRadius="2" />
                        <Border
                            x:Name="barForca3"
                            Grid.Column="2"
                            Height="4"
                            Margin="0,0,3,0"
                            Background="#E8ECF0"
                            CornerRadius="2" />
                        <Border
                            x:Name="barForca4"
                            Grid.Column="3"
                            Height="4"
                            Background="#E8ECF0"
                            CornerRadius="2" />
                    </Grid>
                    <TextBlock
                        x:Name="lblForca"
                        Margin="0,4,0,18"
                        FontFamily="Segoe UI"
                        FontSize="11"
                        Foreground="#9CA3AF" />

                    <!--  REQUISITOS DA SENHA  -->
                    <Border
                        Margin="0,0,0,18"
                        Padding="14,12"
                        Background="#F8FAFC"
                        BorderBrush="#E8ECF0"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontFamily="Segoe UI"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="#9CA3AF"
                                Text="REQUISITOS DA SENHA" />

                            <!--  Comprimento mínimo  -->
                            <StackPanel
                                x:Name="rowLength"
                                Margin="0,0,0,6"
                                Orientation="Horizontal">
                                <Ellipse
                                    x:Name="dotLength"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#D1D5DB" />
                                <TextBlock
                                    x:Name="lblLength"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#9CA3AF" />
                            </StackPanel>

                            <!--  Maiúscula  -->
                            <StackPanel
                                x:Name="rowUpper"
                                Margin="0,0,0,6"
                                Orientation="Horizontal">
                                <Ellipse
                                    x:Name="dotUpper"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#D1D5DB" />
                                <TextBlock
                                    x:Name="lblUpper"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#9CA3AF"
                                    Text="Letra maiúscula" />
                            </StackPanel>

                            <!--  Minúscula  -->
                            <StackPanel
                                x:Name="rowLower"
                                Margin="0,0,0,6"
                                Orientation="Horizontal">
                                <Ellipse
                                    x:Name="dotLower"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#D1D5DB" />
                                <TextBlock
                                    x:Name="lblLower"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#9CA3AF"
                                    Text="Letra minúscula" />
                            </StackPanel>

                            <!--  Número  -->
                            <StackPanel
                                x:Name="rowNumber"
                                Margin="0,0,0,6"
                                Orientation="Horizontal">
                                <Ellipse
                                    x:Name="dotNumber"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#D1D5DB" />
                                <TextBlock
                                    x:Name="lblNumber"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#9CA3AF"
                                    Text="Número" />
                            </StackPanel>

                            <!--  Especial  -->
                            <StackPanel x:Name="rowSpecial" Orientation="Horizontal">
                                <Ellipse
                                    x:Name="dotSpecial"
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Fill="#D1D5DB" />
                                <TextBlock
                                    x:Name="lblSpecial"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="#9CA3AF" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  AVISO LISTA DE USUÁRIOS (visível apenas quando múltiplos)  -->
                    <Border
                        x:Name="panelMultiplos"
                        Margin="0,0,0,10"
                        Padding="14,10"
                        Background="#FFFBEB"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#D97706"
                                Text="⚠" />
                            <TextBlock
                                x:Name="lblMultiplos"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#92400E"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  ═══ RODAPÉ BOTÕES ═══  -->
            <Border
                Grid.Row="2"
                Padding="24,16"
                BorderBrush="#E8ECF0"
                BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Click="BtnCancelar_Click"
                        Content="Cancelar"
                        Style="{StaticResource BtnGhost}" />

                    <Button
                        x:Name="btnConfirmar"
                        Grid.Column="2"
                        Click="BtnConfirmar_Click"
                        IsEnabled="False"
                        Style="{StaticResource BtnPrimary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="✉  " />
                            <TextBlock VerticalAlignment="Center" Text="Enviar e confirmar" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
