<Window
    x:Class="CredentialProviderAPP.Views.LoginMFAWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MFA Login"
    Width="350"
    Height="250"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen">

    <Grid>

        <StackPanel
            Width="200"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                Margin="0,0,0,20"
                FontSize="18"
                Foreground="White"
                Text="Digite o código MFA"
                TextAlignment="Center" />

            <TextBox
                x:Name="txtCode"
                Height="40"
                Margin="0,0,0,20"
                HorizontalContentAlignment="Center"
                FontSize="20"
                MaxLength="6" />

            <Button
                Height="40"
                Click="Validar_Click"
                Content="Validar" />

        </StackPanel>

    </Grid>
</Window>