<Window x:Class="CredentialProviderAPP.Views.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="380"
        Height="170"
        Topmost="True"
        ShowInTaskbar="False">
    <Border Background="#1E1E1E" CornerRadius="12" Padding="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Aguarde"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="txtMensagem"
                       Text="Conectando ao serviço..."
                       FontSize="14"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,16"/>

            <Grid Width="300" Height="10" ClipToBounds="True">
                <Border Background="#3A3A3A" CornerRadius="5"/>

                <Border x:Name="barraAnimada"
                        Width="100"
                        Height="10"
                        Background="#4FC3F7"
                        CornerRadius="5"
                        HorizontalAlignment="Left"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="barraTransform" X="-120"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="barraTransform"
                                     Storyboard.TargetProperty="X"
                                     From="-120"
                                     To="320"
                                     Duration="0:0:1.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>