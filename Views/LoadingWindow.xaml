<Window
    x:Class="CredentialProviderAPP.Views.LoadingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="380"
    Height="170"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">
    <Border
        Padding="20"
        Background="#1E1E1E"
        CornerRadius="12">
        <StackPanel VerticalAlignment="Center">
            <TextBlock
                Margin="0,0,0,10"
                HorizontalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="White"
                Text="Aguarde" />

            <TextBlock
                x:Name="txtMensagem"
                Margin="0,0,0,16"
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="White"
                Text="Conectando ao serviço..."
                TextAlignment="Center" />

            <Grid
                Width="300"
                Height="10"
                ClipToBounds="True">
                <Border Background="#3A3A3A" CornerRadius="5" />

                <Border
                    x:Name="barraAnimada"
                    Width="100"
                    Height="10"
                    HorizontalAlignment="Left"
                    Background="#4FC3F7"
                    CornerRadius="5"
                    RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="barraTransform" X="-120" />
                    </Border.RenderTransform>
                </Border>
            </Grid>
        </StackPanel>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation
                        Storyboard.TargetName="barraTransform"
                        Storyboard.TargetProperty="X"
                        From="-120"
                        To="320"
                        Duration="0:0:1.2" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>