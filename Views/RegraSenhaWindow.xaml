<Window
    x:Class="CredentialProviderAPP.Views.RegraSenhaWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Política de Senha"
    Width="720"
    Height="Auto"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>

        <SolidColorBrush x:Key="BgPage" Color="#F5F7FA" />
        <SolidColorBrush x:Key="BorderColor" Color="#E8ECF0" />
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1D23" />
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF" />

        <!--  INPUT  -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1A1D23" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  TOGGLE SWITCH  -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border
                            x:Name="Track"
                            Width="46"
                            Height="26"
                            Background="#D1D5DB"
                            CornerRadius="13">
                            <Ellipse
                                x:Name="Thumb"
                                Width="20"
                                Height="20"
                                Margin="3,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="White">
                                <Ellipse.Effect>
                                    <DropShadowEffect
                                        BlurRadius="4"
                                        Opacity="0.18"
                                        ShadowDepth="1"
                                        Color="#000" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Thumb" Property="Fill" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO PRIMARY  -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.22"
                                    ShadowDepth="2"
                                    Color="#2563EB" />
                            </Border.Effect>
                            <ContentPresenter
                                Margin="18,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO GHOST  -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter
                                Margin="18,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#1A1D23" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--  CARD RAIZ  -->
    <Border
        Background="{StaticResource BgPage}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="32"
                Opacity="0.13"
                ShadowDepth="8" />
        </Border.Effect>

        <StackPanel>

            <!--  ═══ HEADER ═══  -->
            <Border
                Padding="32,22,32,20"
                Background="White"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="14,14,0,0"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                            <TextBlock
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#2563EB"
                                Text="Segurança" />
                            <TextBlock
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="{StaticResource TextMuted}"
                                Text="  ›  " />
                            <TextBlock
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondary}"
                                Text="Política de Senha" />
                        </StackPanel>
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Política de Senha" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondary}"
                            Text="Defina as regras de segurança e requisitos mínimos para as senhas." />
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="Cancelar_Click"
                        Content="✕"
                        Cursor="Hand"
                        FontSize="13"
                        Foreground="{StaticResource TextMuted}" />
                </Grid>
            </Border>

            <!--  ═══ CORPO ═══  -->
            <StackPanel Margin="32,24,32,24">

                <!--  ── SEÇÃO 1: COMPRIMENTO E COMPLEXIDADE ──  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="24,20"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="6"
                            Opacity="0.05"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                Background="#EFF6FF"
                                CornerRadius="6">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="#2563EB"
                                    Text="⊟" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimary}"
                                Text="Parâmetros de Comprimento e Complexidade" />
                        </StackPanel>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="Tamanho mínimo da senha" />
                                <TextBox
                                    x:Name="txtTamanhoSenha"
                                    PreviewTextInput="NumeroOnly"
                                    Style="{StaticResource ModernInput}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="Segoe UI"
                                    FontSize="11"
                                    Foreground="{StaticResource TextMuted}"
                                    Text="Recomendado: 8 ou mais caracteres." />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="Quantidade de caracteres especiais" />
                                <TextBox
                                    x:Name="txtQtdEspecial"
                                    PreviewTextInput="NumeroOnly"
                                    Style="{StaticResource ModernInput}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    FontFamily="Segoe UI"
                                    FontSize="11"
                                    Foreground="{StaticResource TextMuted}"
                                    Text="Ex: @, #, $, %" />
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondary}"
                                Text="Caracteres especiais permitidos" />
                            <TextBox
                                x:Name="txtCaracteres"
                                Style="{StaticResource ModernInput}"
                                Text="!@#$%&amp;*" />
                            <TextBlock
                                Margin="0,5,0,0"
                                FontFamily="Segoe UI"
                                FontSize="11"
                                Foreground="{StaticResource TextMuted}"
                                Text="Liste todos os símbolos que os usuários podem utilizar." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── SEÇÃO 2: REQUISITOS ADICIONAIS ──  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="24,20"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="6"
                            Opacity="0.05"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                Background="#EFF6FF"
                                CornerRadius="6">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#2563EB"
                                    Text="≡✓" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimary}"
                                Text="Requisitos Adicionais" />
                        </StackPanel>

                        <!--  Maiúscula  -->
                        <Border
                            Margin="0,0,0,16"
                            Padding="0,0,0,16"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontFamily="Segoe UI"
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="Exigir letra maiúscula" />
                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondary}"
                                        Text="A senha deve conter ao menos uma letra de A-Z." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="chkMaiuscula"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>
                        </Border>

                        <!--  Minúscula  -->
                        <Border
                            Margin="0,0,0,16"
                            Padding="0,0,0,16"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontFamily="Segoe UI"
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="Exigir letra minúscula" />
                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondary}"
                                        Text="A senha deve conter ao menos uma letra de a-z." />
                                </StackPanel>
                                <CheckBox
                                    x:Name="chkMinuscula"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ToggleSwitch}" />
                            </Grid>
                        </Border>

                        <!--  Número  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    FontWeight="Medium"
                                    Foreground="{StaticResource TextPrimary}"
                                    Text="Exigir número" />
                                <TextBlock
                                    Margin="0,3,0,0"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondary}"
                                    Text="A senha deve conter ao menos um dígito de 0-9." />
                            </StackPanel>
                            <CheckBox
                                x:Name="chkNumero"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Style="{StaticResource ToggleSwitch}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  ── SEÇÃO 3: EXPIRAÇÃO DE SENHA ──  -->
                <Border
                    Margin="0,0,0,16"
                    Padding="24,20"
                    Background="White"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="6"
                            Opacity="0.05"
                            ShadowDepth="1" />
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20" Orientation="Horizontal">
                            <Border
                                Width="28"
                                Height="28"
                                Margin="0,0,10,0"
                                Background="#FFF7ED"
                                CornerRadius="6">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="#EA580C"
                                    Text="⏱" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimary}"
                                Text="Expiração de Senha" />
                        </StackPanel>

                        <!--  Toggle ativar expiração  -->
                        <Border
                            Margin="0,0,0,16"
                            Padding="0,0,0,16"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontFamily="Segoe UI"
                                        FontSize="13"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource TextPrimary}"
                                        Text="Ativar expiração de senha" />
                                    <TextBlock
                                        Margin="0,3,0,0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondary}"
                                        Text="Usuários serão obrigados a redefinir a senha após o período definido."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <CheckBox
                                    x:Name="chkExpiracaoAtiva"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Checked="ChkExpiracao_Changed"
                                    Style="{StaticResource ToggleSwitch}"
                                    Unchecked="ChkExpiracao_Changed" />
                            </Grid>
                        </Border>

                        <!--  Campo dias — desabilitado quando toggle está OFF  -->
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,6"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextSecondary}"
                                Text="Dias até expiração" />
                            <TextBox
                                x:Name="txtDiasExpiracao"
                                IsEnabled="False"
                                PreviewTextInput="NumeroOnly"
                                Style="{StaticResource ModernInput}" />
                            <TextBlock
                                Margin="0,5,0,0"
                                FontFamily="Segoe UI"
                                FontSize="11"
                                Foreground="{StaticResource TextMuted}"
                                Text="Ex: 90 dias. Recomendado entre 60 e 180 dias." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  ── BANNER DICA ──  -->
                <Border
                    Margin="0,0,0,24"
                    Padding="16,14"
                    Background="#EFF6FF"
                    BorderBrush="#BFDBFE"
                    BorderThickness="1"
                    CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Grid.Column="0"
                            Width="32"
                            Height="32"
                            Margin="0,0,14,0"
                            VerticalAlignment="Top"
                            Background="#DBEAFE"
                            CornerRadius="8">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="#2563EB"
                                Text="ℹ" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="#1D4ED8"
                                Text="Dica de Segurança" />
                            <TextBlock
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#1E40AF"
                                LineHeight="18"
                                TextWrapping="Wrap">
                                As alterações na política de senha não afetarão as senhas atuais dos
                                usuários imediatamente. Eles serão solicitados a atualizar suas senhas
                                na próxima vez que precisarem realizar uma alteração obrigatória.
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  ── BOTÕES ──  -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Click="Cancelar_Click"
                        Content="Cancelar"
                        Style="{StaticResource BtnGhost}" />
                    <Button
                        x:Name="btnSalvar"
                        Click="Salvar_Click"
                        Style="{StaticResource BtnPrimary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="💾  " />
                            <TextBlock
                                x:Name="lblBtnSalvar"
                                VerticalAlignment="Center"
                                Text="Salvar Alterações" />
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>
