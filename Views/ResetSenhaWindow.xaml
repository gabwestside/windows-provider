<Window
    x:Class="CredentialProviderAPP.Views.ResetSenhaWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Redefinir Senha"
    Width="440"
    Height="430"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    WindowStyle="SingleBorderWindow"
    Topmost="True"
    Deactivated="Window_Deactivated"
    Closing="Window_Closing"
    Background="#F5F7FA">

    <Grid>
        <Border
            Width="340"
            Padding="26"
            Background="White"
            CornerRadius="8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderBrush="#D6D6D6"
            BorderThickness="1">

            <StackPanel>
                <TextBlock
                    x:Name="lblTitulo"
                    Text="Validação MFA"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Margin="0,0,0,22"
                    TextAlignment="Center"/>

                <TextBlock
                    Text="Usuário"
                    FontSize="13"/>

                <TextBox
                    x:Name="txtLogin"
                    Height="38"
                    Margin="0,6,0,18"
                    Padding="8"
                    IsReadOnly="True"
                    Background="#F0F0F0"/>

                <TextBlock
                    x:Name="lblCodigo"
                    Text="Código do aplicativo"
                    FontSize="13"/>

                <TextBlock
                    x:Name="lblMetodoInfo"
                    Margin="0,6,0,12"
                    FontSize="12"
                    Foreground="#666666"
                    TextWrapping="Wrap"
                    Visibility="Collapsed"/>

                <TextBox
                    x:Name="txtCode"
                    Height="44"
                    Margin="0,6,0,22"
                    FontSize="24"
                    MaxLength="6"
                    HorizontalContentAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button
                        x:Name="btnValidar"
                        Width="120"
                        Height="38"
                        Margin="4"
                        Background="#2D89EF"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="Validar_Click"
                        Content="Validar"/>

                    <Button
                        x:Name="btnCancelar"
                        Width="120"
                        Height="38"
                        Margin="4"
                        Background="#E1E1E1"
                        BorderThickness="0"
                        Click="Cancelar_Click"
                        Content="Cancelar"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>