<Window
    x:Class="CredentialProviderAPP.Views.ResetSenhaWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Redefinir Senha"
    Width="440"
    Height="430"
    Background="#F5F7FA"
    Closing="Window_Closing"
    Deactivated="Window_Deactivated"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True">

    <Grid>
        <Border
            Width="340"
            Padding="26"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            BorderBrush="#D6D6D6"
            BorderThickness="1"
            CornerRadius="8">

            <StackPanel>
                <TextBlock
                    x:Name="lblTitulo"
                    Margin="0,0,0,22"
                    FontSize="22"
                    FontWeight="SemiBold"
                    Text="Validação MFA"
                    TextAlignment="Center" />

                <TextBlock FontSize="13" Text="Usuário" />

                <TextBox
                    x:Name="txtLogin"
                    Height="38"
                    Margin="0,6,0,18"
                    Padding="8"
                    Background="#F0F0F0"
                    IsReadOnly="True" />

                <TextBlock
                    x:Name="lblCodigo"
                    FontSize="13"
                    Text="Código do aplicativo" />

                <TextBlock
                    x:Name="lblMetodoInfo"
                    Margin="0,6,0,12"
                    FontSize="12"
                    Foreground="#666666"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />

                <TextBox
                    x:Name="txtCode"
                    Height="44"
                    Margin="0,6,0,22"
                    HorizontalContentAlignment="Center"
                    FontSize="24"
                    MaxLength="6" />

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        x:Name="btnValidar"
                        Width="120"
                        Height="38"
                        Margin="4"
                        Background="#2D89EF"
                        BorderThickness="0"
                        Click="Validar_Click"
                        Content="Validar"
                        FontWeight="SemiBold"
                        Foreground="White" />

                    <Button
                        x:Name="btnCancelar"
                        Width="120"
                        Height="38"
                        Margin="4"
                        Background="#E1E1E1"
                        BorderThickness="0"
                        Click="Cancelar_Click"
                        Content="Cancelar" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>