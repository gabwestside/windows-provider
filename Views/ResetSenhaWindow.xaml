<Window
    x:Class="CredentialProviderAPP.Views.ResetSenhaWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    Title="Redefinir Senha"

    Width="420"
    Height="360"

    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    ShowInTaskbar="False"
    WindowStyle="SingleBorderWindow"
    Topmost="True"

    Loaded="Window_Loaded"
    Deactivated="Window_Deactivated"
    Closing="Window_Closing"

    Background="#F5F7FA">

    <Grid>

        <Border
            Width="320"
            Padding="30"
            Background="White"
            CornerRadius="8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderBrush="#D6D6D6"
            BorderThickness="1">

            <StackPanel>

                <TextBlock
                    Text="Validação MFA"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Margin="0,0,0,25"
                    TextAlignment="Center"/>

                <TextBlock
                    Text="Usuário"
                    FontSize="13"/>

                <TextBox
                    x:Name="txtLogin"
                    Height="38"
                    Margin="0,6,0,20"
                    Padding="8"
                    IsReadOnly="True"
                    Background="#F0F0F0"/>

                <TextBlock
                    Text="Código do aplicativo"
                    FontSize="13"/>

                <TextBox
                    x:Name="txtCode"
                    Height="45"
                    Margin="0,6,0,25"
                    FontSize="24"
                    MaxLength="6"
                    HorizontalContentAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button
                        Width="120"
                        Height="40"
                        Margin="4"
                        Background="#2D89EF"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="Validar_Click"
                        Content="Validar"/>

                    <Button
                        Width="120"
                        Height="40"
                        Margin="4"
                        Background="#E1E1E1"
                        BorderThickness="0"
                        Click="Cancelar_Click"
                        Content="Cancelar"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>