<Window
    x:Class="CredentialProviderAPP.Views.ConfiguracoesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configurações"
    Width="480"
    Height="560"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None">

    <Window.Resources>

        <!--  INPUT NORMAL  -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1A1D23" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  PASSWORD BOX  -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="#1A1D23" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO PRIMARY  -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.22"
                                    ShadowDepth="2"
                                    Color="#2563EB" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#B8C4E0" />
                                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO GHOST  -->
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="BorderBrush" Value="#E8ECF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="#1A1D23" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EBF0F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  BOTÃO ÍCONE (mostrar/ocultar senha)  -->
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!--  CARD RAIZ  -->
    <Border
        Background="White"
        BorderBrush="#E8ECF0"
        BorderThickness="1"
        CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="32"
                Opacity="0.14"
                ShadowDepth="8" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Header  -->
                <RowDefinition Height="*" />
                <!--  Corpo  -->
                <RowDefinition Height="Auto" />
                <!--  Rodapé  -->
            </Grid.RowDefinitions>

            <!--  ═══ HEADER ═══  -->
            <Border
                Grid.Row="0"
                BorderBrush="#E8ECF0"
                BorderThickness="0,0,0,1"
                CornerRadius="14,14,0,0"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="24,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Ícone  -->
                    <Border
                        Grid.Column="0"
                        Width="38"
                        Height="38"
                        Margin="0,0,14,0"
                        Background="#EFF6FF"
                        CornerRadius="10">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Text="⚙" />
                    </Border>

                    <!--  Título  -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock
                            FontFamily="Segoe UI"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#1A1D23"
                            Text="Configurações" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontFamily="Segoe UI"
                            FontSize="12"
                            Foreground="#9CA3AF"
                            Text="Administrador do sistema" />
                    </StackPanel>

                    <!--  Fechar  -->
                    <Button
                        Grid.Column="2"
                        Width="28"
                        Height="28"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="BtnFechar_Click"
                        Content="✕"
                        Cursor="Hand"
                        FontSize="13"
                        Foreground="#9CA3AF" />
                </Grid>
            </Border>

            <!--  ═══ CORPO ═══  -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,28,8">

                    <!--  SEÇÃO: CREDENCIAIS DO ADMIN  -->
                    <TextBlock
                        Margin="0,0,0,16"
                        FontFamily="Segoe UI"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="#9CA3AF"
                        Text="CREDENCIAIS DO ADMINISTRADOR" />

                    <!--  Banner info  -->
                    <Border
                        Margin="0,0,0,20"
                        Padding="14,10"
                        Background="#EFF6FF"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,1,10,0"
                                VerticalAlignment="Top"
                                FontSize="14"
                                Foreground="#2563EB"
                                Text="ℹ" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#1D4ED8"
                                TextWrapping="Wrap">
                                Estas credenciais são usadas no fluxo de<Bold>esqueci minha senha</Bold>
                                ,
                                onde o usuário comum se autentica para solicitar a troca de senha no AD.</TextBlock>
                        </StackPanel>
                    </Border>

                    <!--  Login  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="Login do administrador" />
                    <TextBox
                        x:Name="txtLogin"
                        Margin="0,0,0,18"
                        Style="{StaticResource ModernInput}" />

                    <!--  Nova senha  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="Nova senha" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox
                            x:Name="pwdNovaSenha"
                            Grid.Column="0"
                            PasswordChanged="Pwd_Changed"
                            Style="{StaticResource ModernPasswordBox}" />
                        <TextBox
                            x:Name="txtNovaSenhaVisivel"
                            Grid.Column="0"
                            Style="{StaticResource ModernInput}"
                            TextChanged="TxtSenha_Changed"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="btnMostrarNova"
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Click="BtnMostrarNova_Click"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                x:Name="lblOlhoNova"
                                FontSize="13"
                                Foreground="#9CA3AF"
                                Text="👁" />
                        </Button>
                    </Grid>

                    <!--  Confirmar senha  -->
                    <TextBlock
                        Margin="0,0,0,6"
                        FontFamily="Segoe UI"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="#6B7280"
                        Text="Confirmar nova senha" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="44" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox
                            x:Name="pwdConfirmarSenha"
                            Grid.Column="0"
                            PasswordChanged="Pwd_Changed"
                            Style="{StaticResource ModernPasswordBox}" />
                        <TextBox
                            x:Name="txtConfirmarVisivel"
                            Grid.Column="0"
                            Style="{StaticResource ModernInput}"
                            TextChanged="TxtSenha_Changed"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="btnMostrarConfirmar"
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Click="BtnMostrarConfirmar_Click"
                            Style="{StaticResource BtnIcon}">
                            <TextBlock
                                x:Name="lblOlhoConfirmar"
                                FontSize="13"
                                Foreground="#9CA3AF"
                                Text="👁" />
                        </Button>
                    </Grid>

                    <!--  Feedback senhas não conferem  -->
                    <Border
                        x:Name="panelSenhasNaoConferem"
                        Margin="0,4,0,0"
                        Padding="12,8"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#DC2626"
                                Text="⚠" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#DC2626"
                                Text="As senhas não conferem." />
                        </StackPanel>
                    </Border>

                    <!--  Feedback campo senha vazio  -->
                    <Border
                        x:Name="panelSenhaVazia"
                        Margin="0,4,0,0"
                        Padding="12,8"
                        Background="#FFFBEB"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="#D97706"
                                Text="ℹ" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Foreground="#D97706"
                                Text="Deixe as senhas em branco para manter a senha atual."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Status do registro  -->
                    <Border
                        x:Name="panelStatus"
                        Margin="0,16,0,0"
                        Padding="14,10"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                x:Name="lblStatusIcon"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                FontSize="14" />
                            <TextBlock
                                x:Name="lblStatusMsg"
                                VerticalAlignment="Center"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  ═══ RODAPÉ ═══  -->
            <Border
                Grid.Row="2"
                Padding="28,16"
                BorderBrush="#E8ECF0"
                BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Click="BtnCancelar_Click"
                        Content="Cancelar"
                        Style="{StaticResource BtnGhost}" />

                    <Button
                        x:Name="btnSalvar"
                        Grid.Column="2"
                        Click="BtnSalvar_Click"
                        Style="{StaticResource BtnPrimary}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="💾  " />
                            <TextBlock VerticalAlignment="Center" Text="Salvar configurações" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
