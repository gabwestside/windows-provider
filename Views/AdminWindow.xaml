<Window
    x:Class="CredentialProviderAPP.Views.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CredentialProviderAPP"
    Width="1280"
    Height="720"
    AllowsTransparency="True"
    Background="#F5F7FA"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>

        <SolidColorBrush x:Key="BgPage" Color="#F5F7FA" />
        <SolidColorBrush x:Key="BgSurface" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BgNav" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderColor" Color="#E8ECF0" />
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1D23" />
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280" />
        <SolidColorBrush x:Key="TextMuted" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AccentBlue" Color="#2563EB" />
        <SolidColorBrush x:Key="TagBg" Color="#F1F5F9" />
        <SolidColorBrush x:Key="TagText" Color="#475569" />
        <SolidColorBrush x:Key="BadgeBg" Color="#FEF2F2" />
        <SolidColorBrush x:Key="BadgeText" Color="#DC2626" />
        <SolidColorBrush x:Key="BadgeBorder" Color="#FECACA" />
        <SolidColorBrush x:Key="BadgeGreenBg" Color="#F0FDF4" />
        <SolidColorBrush x:Key="BadgeGreenText" Color="#16A34A" />
        <SolidColorBrush x:Key="BadgeGreenBorder" Color="#BBF7D0" />
        <SolidColorBrush x:Key="BadgeYellowBg" Color="#FFFBEB" />
        <SolidColorBrush x:Key="BadgeYellowText" Color="#D97706" />

        <!--  ══ TOGGLE SWITCH ══  -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border
                                x:Name="Track"
                                Width="40"
                                Height="22"
                                VerticalAlignment="Center"
                                Background="#D1D5DB"
                                CornerRadius="11">
                                <Ellipse
                                    x:Name="Thumb"
                                    Width="16"
                                    Height="16"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Fill="White">
                                    <Ellipse.Effect>
                                        <DropShadowEffect
                                            BlurRadius="4"
                                            Opacity="0.15"
                                            ShadowDepth="1"
                                            Color="#000000" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                            <ContentPresenter
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ BOTÃO GHOST ══  -->
        <Style x:Key="BtnGhostStyle" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EBF0F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ COMBOBOX ══  -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{StaticResource TextMuted}"
                                        Text="⌄" />
                                </Grid>
                            </Border>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom">
                                <Border
                                    Margin="0,4,0,0"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="16"
                                            Opacity="0.10"
                                            ShadowDepth="4" />
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ SEARCH BOX ══  -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{StaticResource TextMuted}"
                                    Text="🔍" />
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ NAV MENU ITEM ══  -->
        <Style x:Key="NavMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="ItemBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <Grid>
                                <ContentPresenter VerticalAlignment="Center" ContentSource="Header" />
                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    IsOpen="{TemplateBinding IsSubmenuOpen}"
                                    Placement="Bottom">
                                    <Border
                                        Margin="0,4,0,0"
                                        Padding="6"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="20"
                                                Opacity="0.12"
                                                ShadowDepth="4" />
                                        </Border.Effect>
                                        <ItemsPresenter />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F5F7FA" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF" />
                                <Setter Property="Foreground" Value="#2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Sub-itens normais  -->
        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="SubBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SubBorder" Property="Background" Value="#F5F7FA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SubBorder" Property="Background" Value="#EFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Sub-item roxo (Senha)  -->
        <Style x:Key="SubMenuItemAccentStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#7C3AED" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="SubBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SubBorder" Property="Background" Value="#F5F3FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SubBorder" Property="Background" Value="#EDE9FE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ DATAGRID HEADER ══  -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Content}" />
                                <TextBlock
                                    x:Name="SortArrow"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="9"
                                    Foreground="{StaticResource TextMuted}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▲" />
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Text" Value="▼" />
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  ══ DATAGRID CÉLULA ══  -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,12" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                    <Setter Property="BorderThickness" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══ DATAGRID LINHA ══  -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFC" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  ══ BOTÃO PAGINAÇÃO ══  -->
        <Style x:Key="PagBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F7FA" />
                                <Setter Property="BorderBrush" Value="#2563EB" />
                                <Setter Property="Foreground" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EFF6FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderColor}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="6,4" />
        </Style>

    </Window.Resources>

    <Border
        Background="{StaticResource BgPage}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="30"
                Opacity="0.12"
                ShadowDepth="6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ══ NAV BAR ══  -->
            <Border
                Grid.Row="0"
                Background="{StaticResource BgNav}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="12,12,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Height="56" Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  LOGO  -->
                    <TextBlock
                        Grid.Column="0"
                        Margin="0,0,24,0"
                        VerticalAlignment="Center"
                        FontFamily="Segoe UI"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="CredentialProviderAPP" />

                    <!--  MENU PRINCIPAL  -->
                    <Menu
                        Grid.Column="1"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0">

                        <Menu.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </Menu.ItemsPanel>

                        <!--  USUÁRIOS  -->
                        <Border
                            x:Name="NavUsuariosBorder"
                            Margin="0,0,4,0"
                            VerticalAlignment="Stretch"
                            BorderBrush="#2563EB"
                            BorderThickness="0,0,0,2">

                            <MenuItem
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                Foreground="#2563EB"
                                Header="Usuários"
                                Style="{StaticResource NavMenuItemStyle}" />
                        </Border>

                        <!--  SEGURANÇA  -->
                        <MenuItem
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Header="Segurança"
                            Style="{StaticResource NavMenuItemStyle}">

                            <!--  SUBMENU  -->
                            <MenuItem
                                Click="MenuRegraSenha_Click"
                                Header="Regra de Senha"
                                Style="{StaticResource SubMenuItemStyle}" />

                        </MenuItem>

                        <!--  CONFIGURAÇÕES  -->
                        <MenuItem
                            VerticalAlignment="Center"
                            Click="MenuConfiguracoes_Click"
                            Header="Configurações"
                            Style="{StaticResource NavMenuItemStyle}" />

                    </Menu>

                    <!--  PERFIL + FECHAR  -->
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Border
                            Width="34"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="{StaticResource TagBg}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="17"
                            Cursor="Hand">

                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="👤" />
                        </Border>

                        <Button
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnFechar_Click"
                            Content="✕"
                            Cursor="Hand"
                            FontSize="12"
                            Foreground="{StaticResource TextMuted}" />

                    </StackPanel>

                </Grid>
            </Border>

            <!--  ══ CONTEÚDO ══  -->
            <ScrollViewer
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Grid Margin="32,28,32,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  PAGE HEADER  -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimary}"
                            Text="Cadastro de Usuários" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal">

                            <!--  Atualizar  -->
                            <Button
                                Margin="0,0,10,0"
                                Click="Atualizar_Click"
                                Style="{StaticResource BtnGhostStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="↺" />
                                    <TextBlock VerticalAlignment="Center" Text="Atualizar" />
                                </StackPanel>
                            </Button>

                            <!--
                                ════════════════════════════════════════════════════
                                BOTÃO "FUNÇÕES" — usa Button + ContextMenu
                                Esta abordagem garante que o popup SEMPRE abre.
                                ════════════════════════════════════════════════════
                            -->
                            <Button
                                x:Name="btnFuncoes"
                                VerticalAlignment="Center"
                                Click="BtnFuncoes_Click"
                                Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="FuncoesBtn"
                                            Padding="16,9"
                                            Background="#2563EB"
                                            CornerRadius="8">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="12"
                                                    Opacity="0.30"
                                                    ShadowDepth="2"
                                                    Color="#2563EB" />
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    Foreground="White"
                                                    Text="⚙" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="Funções" />
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="11"
                                                    Foreground="#BFD4FF"
                                                    Text=" ▾" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FuncoesBtn" Property="Background" Value="#1D4ED8" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="FuncoesBtn" Property="Background" Value="#1E40AF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>

                                <!--  ContextMenu — abre abaixo do botão via BtnFuncoes_Click  -->
                                <Button.ContextMenu>
                                    <ContextMenu
                                        x:Name="ctxFuncoes"
                                        Padding="6"
                                        Background="White"
                                        BorderBrush="{StaticResource BorderColor}"
                                        BorderThickness="1">
                                        <ContextMenu.Template>
                                            <ControlTemplate TargetType="ContextMenu">
                                                <Border
                                                    MinWidth="280"
                                                    Padding="6"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderColor}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                    <Border.Effect>
                                                        <DropShadowEffect
                                                            BlurRadius="20"
                                                            Opacity="0.13"
                                                            ShadowDepth="4" />
                                                    </Border.Effect>
                                                    <ItemsPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </ContextMenu.Template>

                                        <!--  ── SEÇÃO MFA ──  -->
                                        <MenuItem IsHitTestVisible="False" Style="{StaticResource SubMenuItemStyle}">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextMuted}"
                                                    Text="MFA" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <MenuItem
                                            Click="AtivarMFASelecionados_Click"
                                            Header="✅  Ativar MFA — Selecionados"
                                            Style="{StaticResource SubMenuItemStyle}" />
                                        <MenuItem
                                            Click="AtivarMFATodos_Click"
                                            Header="✅  Ativar MFA — TODOS não configurados"
                                            Style="{StaticResource SubMenuItemStyle}" />

                                        <Separator />

                                        <MenuItem
                                            Click="ResetarMFASelecionados_Click"
                                            Header="🔄  Resetar MFA — Selecionados"
                                            Style="{StaticResource SubMenuItemStyle}" />
                                        <MenuItem
                                            Click="ResetarMFATodos_Click"
                                            Header="🔄  Resetar MFA — TODOS"
                                            Style="{StaticResource SubMenuItemStyle}" />

                                        <Separator />

                                        <MenuItem
                                            Click="RemoverMFASelecionados_Click"
                                            Header="❌  Remover MFA — Selecionados"
                                            Style="{StaticResource SubMenuItemStyle}" />
                                        <MenuItem
                                            Click="RemoverMFATodos_Click"
                                            Header="❌  Remover MFA — TODOS"
                                            Style="{StaticResource SubMenuItemStyle}" />

                                        <Separator />

                                        <!--  ── SEÇÃO SENHA ──  -->
                                        <MenuItem IsHitTestVisible="False" Style="{StaticResource SubMenuItemStyle}">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextMuted}"
                                                    Text="SENHA" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <MenuItem
                                            Click="TrocarSenhaProximoLoginSelecionados_Click"
                                            Header="🔑  Trocar senha no próximo login — Selecionados"
                                            Style="{StaticResource SubMenuItemAccentStyle}" />
                                        <MenuItem
                                            Click="TrocarSenhaProximoLoginTodos_Click"
                                            Header="🔑  Trocar senha no próximo login — TODOS"
                                            Style="{StaticResource SubMenuItemAccentStyle}" />

                                        <MenuItem IsHitTestVisible="False">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    Margin="0,0,0,4"
                                                    FontSize="11"
                                                    Foreground="{StaticResource TextMuted}"
                                                    Text="Força o fluxo de primeiro acesso" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                        </StackPanel>
                    </Grid>

                    <!--  FILTROS CARD  -->
                    <Border
                        Grid.Row="2"
                        Padding="20,16"
                        Background="White"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="8"
                                Opacity="0.05"
                                ShadowDepth="1" />
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Width="150">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontFamily="Segoe UI"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextMuted}"
                                    Text="FILTRAR POR" />
                                <ComboBox
                                    x:Name="cmbFiltro"
                                    SelectedIndex="0"
                                    Style="{StaticResource ModernComboBox}">
                                    <ComboBoxItem Content="Login" />
                                    <ComboBoxItem Content="Nome" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    FontFamily="Segoe UI"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextMuted}"
                                    Text="PESQUISAR" />
                                <TextBox
                                    x:Name="txtPesquisa"
                                    Style="{StaticResource SearchBoxStyle}"
                                    TextChanged="FiltroAlterado" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="4"
                                Margin="0,4,0,0"
                                VerticalAlignment="Center">
                                <CheckBox
                                    x:Name="chkUsuariosAD"
                                    Margin="0,0,0,10"
                                    Checked="FiltroAlterado"
                                    Content="Usuários AD"
                                    IsChecked="True"
                                    Style="{StaticResource ToggleSwitchStyle}"
                                    Unchecked="FiltroAlterado" />
                                <CheckBox
                                    x:Name="chkUsuariosLocais"
                                    Checked="FiltroAlterado"
                                    Content="Usuários Locais"
                                    Style="{StaticResource ToggleSwitchStyle}"
                                    Unchecked="FiltroAlterado" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  TABELA  -->
                    <Border
                        Grid.Row="4"
                        Background="White"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="8"
                                Opacity="0.05"
                                ShadowDepth="1" />
                        </Border.Effect>

                        <DataGrid
                            x:Name="dgUsuarios"
                            Height="300"
                            Margin="20,8,20,0"
                            AlternationCount="2"
                            AutoGenerateColumns="False"
                            Background="Transparent"
                            BorderThickness="0"
                            CanUserAddRows="False"
                            CanUserResizeColumns="True"
                            EnableRowVirtualization="True"
                            GridLinesVisibility="None"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            RowHeaderWidth="0"
                            SelectionMode="Extended"
                            SelectionUnit="FullRow"
                            Sorting="dgUsuarios_Sorting"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling">

                            <DataGrid.Columns>

                                <!--  ══ COLUNA CHECKBOX "SELECIONAR TODOS" ══  -->
                                <DataGridTemplateColumn
                                    Width="44"
                                    CanUserResize="False"
                                    CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <!--  Checkbox no cabeçalho = selecionar/desselecionar todos  -->
                                            <CheckBox
                                                x:Name="chkSelectAll"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Click="ChkSelectAll_Click"
                                                ToolTip="Selecionar / Desselecionar todos" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                                                IsHitTestVisible="False" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  DATA DE CADASTRO  -->
                                <DataGridTextColumn
                                    Width="155"
                                    Binding="{Binding DataCadastro}"
                                    Header="DATA DE CADASTRO"
                                    SortMemberPath="DataCadastro">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="FontFamily" Value="Segoe UI" />
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!--  TIPO  -->
                                <DataGridTemplateColumn
                                    Width="105"
                                    Header="TIPO"
                                    SortMemberPath="Tipo">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource TagBg}"
                                                CornerRadius="6">
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource TagText}"
                                                    Text="{Binding Tipo}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  LOGIN  -->
                                <DataGridTextColumn
                                    Width="160"
                                    Binding="{Binding Login}"
                                    Header="LOGIN"
                                    SortMemberPath="Login">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="FontFamily" Value="Segoe UI" />
                                            <Setter Property="FontWeight" Value="Medium" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!--  NOME COMPLETO  -->
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding NomeCompleto}"
                                    Header="NOME COMPLETO"
                                    SortMemberPath="NomeCompleto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="13" />
                                            <Setter Property="FontFamily" Value="Segoe UI" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!--  MFA BADGE  -->
                                <DataGridTemplateColumn
                                    Width="145"
                                    Header="MFA"
                                    SortMemberPath="MFAStatus">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BadgeBg}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource BadgeBorder}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MFAStatus}" Value="Ativo">
                                                                <Setter Property="Background" Value="{StaticResource BadgeGreenBg}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource BadgeGreenBorder}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding MFAStatus}" Value="Pendente">
                                                                <Setter Property="Background" Value="{StaticResource BadgeYellowBg}" />
                                                                <Setter Property="BorderBrush" Value="#FDE68A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    FontFamily="Segoe UI"
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Text="{Binding MFAStatus}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource BadgeText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MFAStatus}" Value="Ativo">
                                                                    <Setter Property="Foreground" Value="{StaticResource BadgeGreenText}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding MFAStatus}" Value="Pendente">
                                                                    <Setter Property="Foreground" Value="{StaticResource BadgeYellowText}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  PAGINAÇÃO  -->
                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="lblTotal"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondary}" />

                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                x:Name="btnAnterior"
                                Margin="0,0,6,0"
                                Click="PaginaAnterior_Click"
                                Content="‹"
                                Style="{StaticResource PagBtnStyle}" />
                            <Border
                                Margin="0,0,6,0"
                                Padding="12,0"
                                Background="White"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <TextBlock
                                    x:Name="lblPagina"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe UI"
                                    FontSize="13"
                                    Foreground="{StaticResource TextPrimary}" />
                            </Border>
                            <Button
                                x:Name="btnProxima"
                                Click="ProximaPagina_Click"
                                Content="›"
                                Style="{StaticResource PagBtnStyle}" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </ScrollViewer>

            <!--  RODAPÉ  -->
            <Border
                Grid.Row="2"
                Padding="32,12"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontFamily="Segoe UI"
                    FontSize="11"
                    Foreground="{StaticResource TextMuted}"
                    Text="© 2026 Credential Provider System · Todos os direitos reservados." />
            </Border>
            <!--  ═════════ LOADING OVERLAY ═════════  -->
            <Grid
                x:Name="LoadingOverlay"
                Grid.RowSpan="3"
                Panel.ZIndex="999"
                Background="#80000000"
                Visibility="Collapsed">

                <Border
                    Width="260"
                    Height="140"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="12">

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                        <TextBlock
                            Margin="0,15,0,10"
                            HorizontalAlignment="Center"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Text="Processando..." />

                        <ProgressBar
                            Width="180"
                            Height="16"
                            IsIndeterminate="True" />

                    </StackPanel>

                </Border>

            </Grid>
        </Grid>
    </Border>

</Window>
