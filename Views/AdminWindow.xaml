<Window
    x:Class="CredentialProviderAPP.Views.AdminWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="CredentialProviderAPP"
    Width="1280"
    Height="720"
    Background="#CFE3F6"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#CFEFF7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A4A4A"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>

        <Style x:Key="TextActionStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#5A5A5A"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="4,0,10,0"/>
        </Style>

        <!-- HEADER COM SETA -->
      <Style TargetType="DataGridColumnHeader">

    <Setter Property="Background" Value="#8BBBE6"/>
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="BorderBrush" Value="#6EA5D3"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>

    <Setter Property="Template">
        <Setter.Value>

           <ControlTemplate TargetType="DataGridColumnHeader">

    <Grid Background="{TemplateBinding Background}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- SETA -->
        <TextBlock
            x:Name="SortArrow"
            Grid.Column="0"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            FontSize="12"
            Foreground="#2F5597"
            Visibility="Collapsed"/>

        <!-- TEXTO -->
        <ContentPresenter
            Grid.Column="1"
            VerticalAlignment="Center"
            Margin="4,0,0,0"
            Content="{TemplateBinding Content}"/>

    </Grid>

    <ControlTemplate.Triggers>

        <Trigger Property="SortDirection" Value="Ascending">
            <Setter TargetName="SortArrow" Property="Text" Value="▲"/>
            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
        </Trigger>

        <Trigger Property="SortDirection" Value="Descending">
            <Setter TargetName="SortArrow" Property="Text" Value="▼"/>
            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
        </Trigger>

    </ControlTemplate.Triggers>

</ControlTemplate>

        </Setter.Value>
    </Setter>

</Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

<Style TargetType="DataGridRow">
    <Setter Property="Height" Value="34"/>
    <Setter Property="Background" Value="White"/>

    <Style.Triggers>

        <!-- Zebra -->
        <Trigger Property="AlternationIndex" Value="1">
            <Setter Property="Background" Value="#F3F6FB"/>
        </Trigger>

        <!-- Hover -->
        <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Background" Value="#DCEBFF"/>
        </Trigger>

        <!-- Selecionado -->
        <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#BFD8FF"/>
        </Trigger>

    </Style.Triggers>
</Style>

    </Window.Resources>

    <DockPanel>

    <!-- MENU SUPERIOR -->
    <Menu DockPanel.Dock="Top">

        <MenuItem Header="Usuários"/>

        <MenuItem Header="Segurança">
            <MenuItem
                Header="Regra de Senha"
                Click="MenuRegraSenha_Click"/>
        </MenuItem>

        <MenuItem Header="Configurações"/>

    </Menu>

    <Grid Margin="38,24,38,40">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            FontSize="34"
            FontWeight="Medium"
            Foreground="#5B4B3F"
            Text="Cadastro de Usuários"/>

        <!-- FILTROS -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">

            <StackPanel Orientation="Horizontal">

                <StackPanel Margin="0,0,18,0">

                    <TextBlock FontSize="12" Text="Filtrar por"/>

                    <ComboBox
                        x:Name="cmbFiltro"
                        Width="140"
                        Height="32"
                        SelectedIndex="0">

                        <ComboBoxItem Content="Login"/>
                        <ComboBoxItem Content="Nome"/>

                    </ComboBox>

                </StackPanel>

                <StackPanel>

                    <TextBlock FontSize="12" Text="Pesquisar"/>

                    <TextBox
                        x:Name="txtPesquisa"
                        Width="260"
                        Height="32"
                        TextChanged="FiltroAlterado"/>

                </StackPanel>

                <StackPanel Margin="20,0,0,0">

                    <CheckBox
                        x:Name="chkUsuariosLocais"
                        Content="Usuários Locais"
                        IsChecked="True"
                        Checked="FiltroAlterado"
                        Unchecked="FiltroAlterado"/>

                    <CheckBox
                        x:Name="chkUsuariosAD"
                        Content="Usuários AD"
                        Checked="FiltroAlterado"
                        Unchecked="FiltroAlterado"/>

                </StackPanel>

            </StackPanel>

        </Border>
<Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
    <StackPanel Orientation="Horizontal">

        <!-- Atualizar -->
        <Button Click="Atualizar_Click"
                Style="{StaticResource ActionButtonStyle}">
            ↺
        </Button>

        <TextBlock Style="{StaticResource TextActionStyle}"
                   Text="Atualizar"/>

        <!-- Menu MFA -->
<Menu Margin="30,0,0,0"
      Background="Transparent"
      BorderThickness="0">

<MenuItem Header="⚙ Funções MFA"
          FontSize="14"
          Padding="12,6"
          Background="#E3EEF9"
          BorderBrush="#7EA6D9"
          BorderThickness="1"
          Cursor="Hand">

                <MenuItem Header="Ativar MFA Selecionados"
                          Click="AtivarMFASelecionados_Click"/>

                <MenuItem Header="Ativar MFA para TODOS não configurados"
                          Click="AtivarMFATodos_Click"/>

                <Separator/>

                <MenuItem Header="Resetar MFA Selecionados"
                          Click="ResetarMFASelecionados_Click"/>

            </MenuItem>

        </Menu>

    </StackPanel>
</Border>
        <!-- TABELA -->
        <Border
            Grid.Row="6"
            Background="White"
            BorderBrush="#9E9E9E"
            BorderThickness="1">

<DataGrid
    x:Name="dgUsuarios"
    AutoGenerateColumns="False"
    AlternationCount="2"
    IsReadOnly="True"
    SelectionMode="Extended"
    SelectionUnit="FullRow"
    Sorting="dgUsuarios_Sorting"
    CanUserResizeColumns="True"
    EnableRowVirtualization="True"
    VirtualizingPanel.IsVirtualizing="True"
    VirtualizingPanel.VirtualizationMode="Recycling">

              <DataGrid.Columns>

<DataGridTextColumn
    Header="Data de Cadastro"
    Binding="{Binding DataCadastro}"
    SortMemberPath="DataCadastro"
    Width="150"/>

<DataGridTextColumn
    Header="Tipo"
    Binding="{Binding Tipo}"
    SortMemberPath="Tipo"
    Width="90"/>

<DataGridTextColumn
    Header="Login"
    Binding="{Binding Login}"
    SortMemberPath="Login"
    Width="150"/>

<DataGridTextColumn
    Header="Nome Completo"
    Binding="{Binding NomeCompleto}"
    SortMemberPath="NomeCompleto"
    Width="*"/>

<DataGridTemplateColumn Header="MFA" Width="140">
    <DataGridTemplateColumn.CellTemplate>
        <DataTemplate>
            <Border Padding="4" CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">

                        <Setter Property="Background" Value="#E0E0E0"/>

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding MFAStatus}" Value="Ativo">
                                <Setter Property="Background" Value="#C8E6C9"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding MFAStatus}" Value="Pendente">
                                <Setter Property="Background" Value="#FFF3CD"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding MFAStatus}" Value="Não configurado">
                                <Setter Property="Background" Value="#FFCDD2"/>
                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </Border.Style>

                <TextBlock
                    Text="{Binding MFAStatus}"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"/>

            </Border>
        </DataTemplate>
    </DataGridTemplateColumn.CellTemplate>
</DataGridTemplateColumn>

</DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- PAGINAÇÃO -->
        <StackPanel
            Grid.Row="7"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,10">

            <Button
                x:Name="btnAnterior"
                Content="◀"
                Width="40"
                Height="28"
                Click="PaginaAnterior_Click"/>

            <TextBlock
                x:Name="lblPagina"
                Margin="10,0"
                VerticalAlignment="Center"
                FontSize="16"
                Text="Página 1"/>

            <Button
                x:Name="btnProxima"
                Content="▶"
                Width="40"
                Height="28"
                Click="ProximaPagina_Click"/>

            <TextBlock
                x:Name="lblTotal"
                Margin="20,0,0,0"
                VerticalAlignment="Center"
                FontSize="14"
                Foreground="#555"/>

        </StackPanel>

</Grid>

</DockPanel>

</Window>