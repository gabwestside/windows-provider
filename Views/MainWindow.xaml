<Window x:Class="CredentialProviderAPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CredentialProviderAPP"
        Width="1280"
        Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#CFE3F6">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#CFEFF7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A4A4A"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>

        <Style x:Key="TextActionStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#5A5A5A"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="4,0,10,0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#8BBBE6"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="#6EA5D3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Margin="38,24,38,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0"
                   Text="Cadastro de Usuários"
                   HorizontalAlignment="Center"
                   FontSize="34"
                   FontWeight="Medium"
                   Foreground="#5B4B3F"
                   Margin="0,0,0,6"/>

        <!-- Área de filtros -->
        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Border Width="620"
                        HorizontalAlignment="Left"
                        Background="#EFEFEF"
                        BorderBrush="#BFBFBF"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="18">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,18,0">
                            <TextBlock Text="Filtrar por"
                                       FontSize="12"
                                       Foreground="#5F5F5F"
                                       Margin="8,0,0,2"/>
                            <ComboBox x:Name="cmbFiltro"
                                      Width="140"
                                      Height="32"
                                      FontSize="15"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="Login"/>
                                <ComboBoxItem Content="Nome"/>
                                <ComboBoxItem Content="Tipo"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text=" "
                                       FontSize="12"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="txtPesquisa"
                                     Width="300"
                                     Height="32"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     Text="Pesquisar"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Barra de ações -->
        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource ActionButtonStyle}" Click="NovoUsuario_Click">⌂</Button>
                <TextBlock Style="{StaticResource TextActionStyle}" Text="+ Novo usuário"/>

                <TextBlock Text="|" Foreground="#8A8A8A" FontSize="22" Margin="12,0"/>

                <Button Style="{StaticResource ActionButtonStyle}" Click="ImportarUsuarios_Click">⇪</Button>
                <TextBlock Style="{StaticResource TextActionStyle}" Text="Importar usuários"/>

                <TextBlock Text="|" Foreground="#8A8A8A" FontSize="22" Margin="12,0"/>

                <Button Style="{StaticResource ActionButtonStyle}" Click="Atualizar_Click">↺</Button>
                <TextBlock Style="{StaticResource TextActionStyle}" Text="Atualizar"/>

                <TextBlock Text="⋮" Foreground="#5A5A5A" FontSize="26" Margin="18,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Style="{StaticResource TextActionStyle}" Text="Gerenciamento"/>

                <TextBlock Text="|" Foreground="#8A8A8A" FontSize="22" Margin="12,0"/>

                <TextBlock Style="{StaticResource TextActionStyle}" Text="Opções"/>
                <TextBlock Text="⋮" Foreground="#5A5A5A" FontSize="26" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabela -->
        <Border Grid.Row="6"
                Background="White"
                BorderBrush="#9E9E9E"
                BorderThickness="1">
            <DataGrid x:Name="dgUsuarios"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="None"
                      RowHeaderWidth="0"
                      Background="White"
                      BorderThickness="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data de Cadastro" Binding="{Binding DataCadastro}" Width="170"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="160"/>
                    <DataGridTextColumn Header="Nome Completo" Binding="{Binding NomeCompleto}" Width="*"/>
                    <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="170"/>
                    <DataGridTemplateColumn Header="Ações" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✎"
                                            Width="28"
                                            Height="24"
                                            Margin="2"
                                            Click="EditarUsuario_Click"/>
                                    <Button Content="🗑"
                                            Width="28"
                                            Height="24"
                                            Margin="2"
                                            Click="ExcluirUsuario_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>