<Window
    x:Class="CredentialProviderAPP.Views.ResetSenhaWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Resetar Senha"
    Width="350"
    Height="280"
    Background="#1E1E1E"
    WindowStartupLocation="CenterScreen">

    <Grid>

        <StackPanel
            Width="220"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                Text="Resetar senha"
                FontSize="20"
                Foreground="White"
                Margin="0,0,0,20"
                TextAlignment="Center"/>

            <TextBox
                x:Name="txtLogin"
                Height="35"
                Margin="0,0,0,10"/>

            <TextBox
                x:Name="txtCode"
                Height="35"
                Margin="0,0,0,20"
                FontSize="20"
                HorizontalContentAlignment="Center"
                MaxLength="6"/>

            <Button
                Height="35"
                Click="Validar_Click"
                Content="Validar MFA"/>

        </StackPanel>

    </Grid>
</Window>