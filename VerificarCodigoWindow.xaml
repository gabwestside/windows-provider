<Window x:Class="CredentialProviderAPP.VerificarCodigoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verificar Código MFA"
        Height="200"
        Width="300"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

<Grid>

<StackPanel VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Width="200">

<TextBlock Text="Digite o código do celular"
           Foreground="White"
           Margin="0,0,0,10"
           TextAlignment="Center"/>

<TextBox x:Name="txtCode"
         Height="35"
         FontSize="18"
         MaxLength="6"
         HorizontalContentAlignment="Center"
         Margin="0,0,0,10"/>

<Button Content="Verificar"
        Height="35"
        Click="Verificar_Click"/>

</StackPanel>

</Grid>
</Window>