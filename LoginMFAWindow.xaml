<Window x:Class="CredentialProviderAPP.LoginMFAWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MFA Login"
        Height="250"
        Width="350"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="200">

            <TextBlock Text="Digite o código MFA"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

            <TextBox x:Name="txtCode"
                     Height="40"
                     FontSize="20"
                     MaxLength="6"
                     Margin="0,0,0,20"
                     HorizontalContentAlignment="Center"/>

            <Button Content="Validar"
                    Height="40"
                    Click="Validar_Click"/>

        </StackPanel>

    </Grid>
</Window>